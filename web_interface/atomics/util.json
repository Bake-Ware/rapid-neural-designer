[
  {
    "name": "Identity",
    "id": "identity",
    "category": "util",
    "description": "Pass-through tensor. x → x. Graph hygiene and debug.",
    "inputs": [
      { "name": "x", "type": "tensor" }
    ],
    "outputs": [
      { "name": "out", "type": "tensor" }
    ],
    "properties": [],
    "code": "{{out}} = {{x}}",
