  {
    "name": "FreeEnergy",
    "id": "free_energy",
    "category": "math",
    "description": "Aggregates prediction errors across layers into a scalar via sum or mean.",
    "inputs": [
      { "name": "errors", "type": "tensor[]" }
    ],
    "outputs": [
      { "name": "energy", "type": "tensor" }
    ],
    "properties": [
      { "name": "reduction", "type": "enum", "default": "sum", "options": ["sum", "mean"], "description": "Reduction method" }
    ],
    "code": "_fe{{_id}}_terms = np.array([float(np.sum(e ** 2)) for e in {{errors}}])\n{{energy}} = np.sum(_fe{{_id}}_terms) if '{{reduction}}' == 'sum' else np.mean(_fe{{_id}}_terms)",
    "imports": ["import numpy as np"],
    "color": "#4ecdc4"
  }
