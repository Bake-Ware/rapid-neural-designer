  {
    "name": "CFGCombiner",
    "id": "cfg_combiner",
    "category": "math",
    "description": "Classifier-free guidance: w·cond_pred + (1-w)·uncond_pred.",
    "inputs": [
      { "name": "cond", "type": "tensor" },
      { "name": "uncond", "type": "tensor" }
    ],
    "outputs": [
      { "name": "out", "type": "tensor" }
    ],
    "properties": [
      { "name": "guidance_scale", "type": "float", "default": 3.0, "description": "CFG guidance weight w" }
    ],
    "code": "{{out}} = {{guidance_scale}} * {{cond}} + (1.0 - {{guidance_scale}}) * {{uncond}}",
    "imports": [],
    "color": "#4ecdc4"
