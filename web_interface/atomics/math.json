    "name": "ForwardNoise",
    "id": "forward_noising",
    "category": "math",
    "description": "Adds Gaussian noise: x + σ·ε where ε ~ N(0, I).",
    "inputs": [
      { "name": "x", "type": "tensor" }
    ],
    "outputs": [
      { "name": "noisy_x", "type": "tensor" }
    ],
    "properties": [
