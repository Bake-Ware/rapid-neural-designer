  {
    "name": "ReLU",
    "id": "relu",
    "category": "trig",
    "description": "Rectified linear unit: max(0, x)",
    "inputs": [
      { "name": "input", "type": "tensor" }
    ],
    "outputs": [
      { "name": "result", "type": "tensor" }
    ],
    "code": "{{result}} = np.maximum(0, {{input}})",
    "imports": ["import numpy as np"],
    "color": "#f0a500"
  },
  {
    "name": "GELU",
    "id": "gelu",
    "category": "trig",
    "description": "Gaussian Error Linear Unit activation",
    "inputs": [
      { "name": "input", "type": "tensor" }
    ],
    "outputs": [
      { "name": "result", "type": "tensor" }
    ],
    "code": "{{result}} = 0.5 * {{input}} * (1.0 + np.tanh(np.sqrt(2.0 / np.pi) * ({{input}} + 0.044715 * np.power({{input}}, 3))))",
    "imports": ["import numpy as np"],
    "color": "#f0a500"
  },
  {
    "name": "Softmax",
    "id": "softmax",
    "category": "trig",
    "description": "Softmax along an axis (numerically stable)",
    "inputs": [
      { "name": "input", "type": "tensor" }
    ],
    "outputs": [
      { "name": "result", "type": "tensor" }
    ],
    "properties": [
      { "name": "axis", "type": "int", "default": -1, "description": "Axis to apply softmax" }
    ],
    "code": "_sm{{_id}} = np.exp({{input}} - np.max({{input}}, axis={{axis}}, keepdims=True))\n{{result}} = _sm{{_id}} / np.sum(_sm{{_id}}, axis={{axis}}, keepdims=True)",
    "imports": ["import numpy as np"],
    "color": "#f0a500"
  }
