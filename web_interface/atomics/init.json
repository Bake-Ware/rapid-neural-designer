[
  {
    "name": "RandomNormal",
    "id": "random_normal",
    "category": "init",
    "description": "Create tensor with random normal values",
    "inputs": [],
    "outputs": [
      { "name": "result", "type": "tensor" }
    ],
    "properties": [
      { "name": "shape", "type": "string", "default": "1,10,512", "description": "Shape as comma-separated ints" },
      { "name": "mean", "type": "float", "default": 0.0, "description": "Mean of distribution" },
      { "name": "std", "type": "float", "default": 0.02, "description": "Standard deviation" }
    ],
    "code": "{{result}} = np.random.randn({{shape}}).astype(np.float32) * {{std}} + {{mean}}",
    "imports": ["import numpy as np"],
    "color": "#fcbad3"
  },
