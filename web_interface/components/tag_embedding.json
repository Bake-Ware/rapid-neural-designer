{
  "name": "TagEmbedding",
  "id": "tag_embedding",
  "description": "Semantic tag embedding attached to weight pockets. Standard embedding lookup by tag index.",
  "inputs": [
    { "name": "tag_indices", "type": "tensor" }
  ],
  "outputs": [
    { "name": "embeddings", "type": "tensor" }
  ],
  "properties": [
    { "name": "vocab_size", "type": "int", "default": 256, "description": "Number of distinct semantic tags" },
    { "name": "embed_dim", "type": "int", "default": 64, "description": "Tag embedding dimension" },
    { "name": "init_std", "type": "float", "default": 0.02, "description": "Embedding init std" }
  ],
  "code": "_tage{{_id}}_table = np.random.randn({{vocab_size}}, {{embed_dim}}).astype(np.float32) * {{init_std}}\n{{embeddings}} = _tage{{_id}}_table[{{tag_indices}}.astype(int)]",
  "imports": ["import numpy as np"]
}
