{
 "name": "Orthogonal Transform",
 "id": "orthogonal_transform",
 "category": "math",
 "description": "Fixed random orthogonal rotation Q (QR-derived) applied to a state vector. Run 6d/7 showed no measurable learning effect (negative result).",
 "inputs": [
  {
   "name": "x",
   "type": "tensor"
  }
 ],
 "outputs": [
  {
   "name": "rotated",
   "type": "tensor"
  }
 ],
 "properties": [
  {
