   "type": "int",
   "default": 256,
   "description": "Dimension"
  }
 ],
 "code": "_ot{{_id}}_Q, _ = np.linalg.qr(np.random.randn({{dim}}, {{dim}}).astype(np.float32))\n{{rotated}} = {{x}} @ _ot{{_id}}_Q",
