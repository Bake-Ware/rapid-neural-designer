{
  "name": "RMSNorm",
  "id": "rmsnorm",
  "description": "Root Mean Square Layer Normalization",
  "inputs": [
    { "name": "input", "type": "tensor" }
  ],
  "outputs": [
    { "name": "output", "type": "tensor" }
  ],
  "properties": [
    { "name": "dim", "type": "int", "default": 512, "description": "Normalization dimension" },
    { "name": "eps", "type": "float", "default": 1e-6, "description": "Epsilon for numerical stability" }
  ],
  "code": "_rms{{_id}}_weight = np.ones({{dim}}, dtype=np.float32)\n_rms{{_id}}_var = np.mean({{input}} ** 2, axis=-1, keepdims=True)\n{{output}} = {{input}} * (1.0 / np.sqrt(_rms{{_id}}_var + {{eps}})) * _rms{{_id}}_weight",
  "imports": ["import numpy as np"],
