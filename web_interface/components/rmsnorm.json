      { "id": 4, "type": "atomic/init/constant", "title": "epsilon", "pos": [180, 160], "properties": { "const_value": 1e-6 } },
      { "id": 5, "type": "atomic/math/add", "title": "+ eps", "pos": [560, 0], "properties": {} },
