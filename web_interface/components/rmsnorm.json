      { "id": 7, "type": "atomic/math/reciprocal", "title": "1/sqrt", "pos": [900, 0], "properties": {} },
      { "id": 8, "type": "atomic/math/multiply", "title": "x * (1/rms)", "pos": [1080, 0], "properties": {} },
      { "id": 9, "type": "atomic/init/ones", "title": "weight (gamma)", "pos": [900, 120], "properties": { "shape": "512" } },
      { "id": 10, "type": "atomic/math/multiply", "title": "* weight", "pos": [1260, 0], "properties": {} }
